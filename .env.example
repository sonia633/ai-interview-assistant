# ---- Application ----
APP_NAME="AI Interview Assistant"
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-in-production

# ---- JWT ----
JWT_SECRET_KEY=change-me-too-another-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- Database ----
POSTGRES_USER=interview
POSTGRES_PASSWORD=interview
POSTGRES_DB=interview_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Full URL is built from the parts above in app/core/config.py, but you can override:
# DATABASE_URL=postgresql+psycopg2://interview:interview@db:5432/interview_db

# ---- Uploads ----
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# ---- Admin bootstrap (created on first startup if not present) ----
FIRST_ADMIN_EMAIL=admin@interview.ai
FIRST_ADMIN_PASSWORD=Admin12345!
